{
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/airtable", "destination": "/api/airtable.js" },
    { "source": "/api/webhook", "destination": "/api/webhook.js" },
    { "source": "/api/password-reset", "destination": "/api/password-reset.js" },
    { "source": "/api/reset-confirm", "destination": "/api/reset-confirm.js" },
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/icon-192.png", "destination": "/public/icon-192.png" },
    { "source": "/icon-512.png", "destination": "/public/icon-512.png" },
    { "source": "/success.html", "destination": "/public/success.html" },
    { "source": "/reset.html", "destination": "/public/reset.html" },
    { "source": "/privacy.html", "destination": "/public/privacy.html" },
    { "source": "/terms.html", "destination": "/public/terms.html" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}
